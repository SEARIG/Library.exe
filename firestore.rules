rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function user() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function profile() {
      return user().data;
    }

    function active() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (profile().status in ["active", "trialing"] || profile().active == true);
    }

    function role() {
      return active() ? profile().role : "";
    }

    function superAdmin() {
      return role() == "super_admin";
    }

    function adminRole() {
      return role() in ["super_admin", "university_admin", "college_admin", "library_admin"];
    }

    function staffRole() {
      return role() in ["super_admin", "university_admin", "college_admin", "library_admin", "librarian"];
    }

    function sameTenant(data) {
      return superAdmin()
        || (
          active()
          && data.orgType == profile().orgType
          && (!("universityId" in data) || data.universityId == null || data.universityId == profile().universityId)
          && (!("collegeId" in data) || data.collegeId == null || data.collegeId == profile().collegeId)
          && (!("libraryId" in data) || data.libraryId == null || data.libraryId == profile().libraryId)
        );
    }

    function ownStudentRecord(data) {
      return active()
        && role() == "student"
        && data.studentUid == request.auth.uid;
    }

    function protectedFieldsClean() {
      return request.resource.data.keys().hasAll(["orgType", "createdAt", "updatedAt", "status"]);
    }

    match /users/{uid} {
      allow read: if superAdmin() || role() == "admin" || request.auth.uid == uid || (staffRole() && sameTenant(resource.data));
      allow create: if request.auth.uid == uid
        && request.resource.data.role == "student"
        && request.resource.data.uid == uid
        && (protectedFieldsClean() || request.resource.data.active == true);
      allow update: if superAdmin()
        || (request.auth.uid == uid
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(["uid", "firebaseAuthUid", "role", "orgType", "universityId", "collegeId", "libraryId", "createdAt"]));
      allow delete: if superAdmin() || role() == "admin";
    }

    match /students/{uid} {
      allow read: if active() && (request.auth.uid == uid || staffRole() || role() == "admin");
      allow create: if active()
        && request.auth.uid == uid
        && request.resource.data.uid == uid;
      allow update: if active()
        && (staffRole() || role() == "admin" || request.auth.uid == uid)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(["uid", "createdAt"]);
      allow delete: if superAdmin() || role() == "admin";
    }

    match /books/{bookId} {
      allow read: if active();
      allow create, update: if active()
        && (staffRole() || role() == "admin")
        && request.resource.data.status in ["available", "issued", "lost", "damaged"];
      allow delete: if superAdmin() || role() == "admin";
    }

    match /bookMetadata/{isbn} {
      allow read: if active();
      allow create, update: if active() && (staffRole() || role() == "admin");
      allow delete: if superAdmin() || role() == "admin";
    }

    match /barcodePrintBatches/{batchId} {
      allow read, create, update: if active() && (staffRole() || role() == "admin");
      allow delete: if superAdmin() || role() == "admin";
    }

    match /barcodePrintLogs/{logId} {
      allow read, create: if active() && (staffRole() || role() == "admin");
      allow update, delete: if superAdmin() || role() == "admin";
    }

    match /bookIssues/{issueId} {
      allow read: if active()
        && (resource.data.studentUid == request.auth.uid || staffRole() || role() == "admin");
      allow create, update: if active() && (staffRole() || role() == "admin");
      allow delete: if superAdmin() || role() == "admin";
    }

    match /penalties/{penaltyId} {
      allow read: if active()
        && (resource.data.studentUid == request.auth.uid || staffRole() || role() == "admin");
      allow write: if false;
    }

    match /counters/{counterId} {
      allow read, create, update: if active() && (staffRole() || role() == "admin");
      allow delete: if superAdmin() || role() == "admin";
    }

    match /universities/{universityId} {
      allow read: if superAdmin() || (active() && profile().universityId == universityId);
      allow create, update, delete: if superAdmin();

      match /colleges/{collegeId} {
        allow read: if superAdmin()
          || (active() && profile().universityId == universityId && (role() == "university_admin" || profile().collegeId == collegeId));
        allow create, update: if superAdmin() || (role() == "university_admin" && profile().universityId == universityId);
        allow delete: if superAdmin();

        match /books/{bookId} {
          allow read: if active() && sameTenant(resource.data);
          allow create, update: if staffRole() && sameTenant(request.resource.data) && protectedFieldsClean();
          allow delete: if adminRole() && sameTenant(resource.data);
        }

        match /students/{studentUid} {
          allow read: if (request.auth.uid == studentUid) || (active() && sameTenant(resource.data));
          allow create, update: if staffRole() && sameTenant(request.resource.data) && protectedFieldsClean();
          allow delete: if adminRole() && sameTenant(resource.data);
        }

        match /staff/{staffId} {
          allow read: if staffRole() && sameTenant(resource.data);
          allow create, update: if adminRole() && sameTenant(request.resource.data);
          allow delete: if adminRole() && sameTenant(resource.data);
        }
      }
    }

    match /independentColleges/{collegeId} {
      allow read: if superAdmin() || (active() && profile().collegeId == collegeId);
      allow create, update, delete: if superAdmin();

      match /books/{bookId} {
        allow read: if active() && sameTenant(resource.data);
        allow create, update: if staffRole() && sameTenant(request.resource.data) && protectedFieldsClean();
        allow delete: if adminRole() && sameTenant(resource.data);
      }

      match /students/{studentUid} {
        allow read: if (request.auth.uid == studentUid) || (active() && sameTenant(resource.data));
        allow create, update: if staffRole() && sameTenant(request.resource.data) && protectedFieldsClean();
        allow delete: if adminRole() && sameTenant(resource.data);
      }

      match /staff/{staffId} {
        allow read: if staffRole() && sameTenant(resource.data);
        allow create, update: if adminRole() && sameTenant(request.resource.data);
        allow delete: if adminRole() && sameTenant(resource.data);
      }
    }

    match /privateLibraries/{libraryId} {
      allow read: if superAdmin() || (active() && profile().libraryId == libraryId);
      allow create, update, delete: if superAdmin();

      match /books/{bookId} {
        allow read: if active() && sameTenant(resource.data);
        allow create, update: if staffRole() && sameTenant(request.resource.data) && protectedFieldsClean();
        allow delete: if adminRole() && sameTenant(resource.data);
      }

      match /members/{studentUid} {
        allow read: if (request.auth.uid == studentUid) || (active() && sameTenant(resource.data));
        allow create, update: if staffRole() && sameTenant(request.resource.data) && protectedFieldsClean();
        allow delete: if adminRole() && sameTenant(resource.data);
      }

      match /staff/{staffId} {
        allow read: if staffRole() && sameTenant(resource.data);
        allow create, update: if adminRole() && sameTenant(request.resource.data);
        allow delete: if adminRole() && sameTenant(resource.data);
      }
    }

    match /issueRequests/{requestId} {
      allow read: if active() && (sameTenant(resource.data) || ownStudentRecord(resource.data));
      allow create: if active()
        && role() == "student"
        && request.resource.data.studentUid == request.auth.uid
        && request.resource.data.status == "pending"
        && sameTenant(request.resource.data)
        && protectedFieldsClean();
      allow update: if staffRole() && sameTenant(resource.data);
      allow delete: if superAdmin();
    }

    match /issueRecords/{issueId} {
      allow read: if active() && (sameTenant(resource.data) || ownStudentRecord(resource.data));
      allow create, update: if staffRole() && sameTenant(request.resource.data);
      allow delete: if superAdmin();
    }

    match /returnRecords/{returnId} {
      allow read: if active() && (sameTenant(resource.data) || ownStudentRecord(resource.data));
      allow create, update: if staffRole() && sameTenant(request.resource.data);
      allow delete: if superAdmin();
    }

    match /lostBookRecords/{lostRecordId} {
      allow read: if staffRole() && sameTenant(resource.data);
      allow create, update: if staffRole() && sameTenant(request.resource.data);
      allow delete: if superAdmin();
    }

    match /subscriptions/{subscriptionId} {
      allow read: if superAdmin() || (adminRole() && sameTenant(resource.data));
      allow write: if superAdmin();
    }

    match /payments/{paymentId} {
      allow read: if superAdmin() || (adminRole() && sameTenant(resource.data));
      allow write: if superAdmin();
    }

    match /emailLogs/{emailId} {
      allow read: if superAdmin();
      allow write: if false;
    }

    match /auditLogs/{logId} {
      allow read: if superAdmin() || (staffRole() && sameTenant(resource.data));
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
